# Private working directory — reviewer feedback, generated reports, personal notes
private/

# macOS
.DS_Store

# Obsidian
.obsidian/

# Build output (generated by GitHub Actions)
dist/

# Raw — per-source workbench
# Track audit trail (source.json, log.md, triage.md, distill.md, critique.md, drafts/**)
# Ignore binaries and full extracted text (copyright)

# Drop zone for new binaries — never tracked
raw/inbox/
!raw/inbox/.gitkeep

# Legacy per-type folders (will be retired after soft-backfill migration to per-source dirs)
raw/papers/
raw/articles/
raw/books/
raw/transcripts/
raw/decks/
raw/other/
raw/processing/

# In every per-source dir raw/<slug>/, ignore the source binary and the full extracted text
raw/*/original.*
raw/*/source.md

# Python build artifacts
__pycache__/
*.pyc
.venv/

# Secrets — never commit
.env
.env.*
!.env.example

# PR body scratch files (used to work around shell quoting in `gh pr create`)
.pr-body*.md
