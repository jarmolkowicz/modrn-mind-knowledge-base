# Private working directory — reviewer feedback, generated reports, personal notes
private/

# macOS
.DS_Store

# Obsidian
.obsidian/

# Build output (generated by GitHub Actions)
dist/

# Raw source files (PDFs, articles) — local only, copyright concerns
# Track folder structure (.gitkeep files), ignore everything else inside
raw/*
!raw/inbox/
!raw/processing/
!raw/papers/
!raw/articles/
!raw/books/
!raw/transcripts/
!raw/decks/
!raw/other/
raw/inbox/*
raw/processing/*
raw/papers/*
raw/articles/*
raw/books/*
raw/transcripts/*
raw/decks/*
raw/other/*
!raw/inbox/.gitkeep
!raw/processing/.gitkeep
!raw/papers/.gitkeep
!raw/articles/.gitkeep
!raw/books/.gitkeep
!raw/transcripts/.gitkeep
!raw/decks/.gitkeep
!raw/other/.gitkeep

# Python build artifacts
__pycache__/
*.pyc
.venv/

# Secrets — never commit
.env
.env.*
!.env.example

# PR body scratch files (used to work around shell quoting in `gh pr create`)
.pr-body*.md
