# Working directory (not curated content)
workspace/

# macOS
.DS_Store

# Obsidian
.obsidian/

# Build output (generated by GitHub Actions)
dist/

# Raw source files (PDFs, articles) — local only, copyright concerns
# Track folder structure (.gitkeep files), ignore everything else inside
raw/**/*
!raw/**/.gitkeep

# Python build artifacts
__pycache__/
*.pyc
.venv/

# Secrets — never commit
.env
.env.*
!.env.example
